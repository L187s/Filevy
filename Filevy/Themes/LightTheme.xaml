<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BgBrush"           Color="#F0F0FF"/>
    <SolidColorBrush x:Key="SurfaceBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBrush"         Color="#F5F5FF"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#DDDDF0"/>
    <SolidColorBrush x:Key="AccentBrush"       Color="#6366F1"/>
    <SolidColorBrush x:Key="AccentHoverBrush"  Color="#7577F5"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#5153D0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#1A1A2E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7777BB"/>
    <SolidColorBrush x:Key="HoverBrush"        Color="#E8E8FF"/>
    <SolidColorBrush x:Key="SelectedBrush"     Color="#DCDCFF"/>
    <SolidColorBrush x:Key="TrackBrush"        Color="#E0E0F5"/>
</ResourceDictionary>