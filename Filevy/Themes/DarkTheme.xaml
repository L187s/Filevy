    <SolidColorBrush x:Key="CardBrush"         Color="#1C1C35"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#2A2A50"/>
    <SolidColorBrush x:Key="AccentBrush"       Color="#6366F1"/>
