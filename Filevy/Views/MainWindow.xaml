<Window x:Class="Filevy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Filevy" Height="660" Width="1020"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgBrush}">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="⬡" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="  Filevy" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="─" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                    <Button Content="□" Style="{StaticResource TitleBarButton}" Click="MaximizeButton_Click"/>
                    <Button Content="✕" Style="{StaticResource CloseButton}"    Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SelectedFileName, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="36"/>

                <Button Grid.Column="1"
                        Content="Select File"
                        Command="{Binding SelectFileCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Height="36" Margin="8,0"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AvailableFormats}"
                          SelectedItem="{Binding SelectedFormat}"
                          Height="36"/>

                <Button Grid.Column="3"
                        Content="Convert →"
                        Command="{Binding ConvertCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="36" Margin="8,0,0,0"/>

                <Button Grid.Column="4"
                        Content="{Binding ThemeIcon}"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource GhostButton}"
                        Height="36" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Job List -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  SelectionMode="Single"
                  Margin="20,16,20,0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="INPUT FILE"  Width="220" DisplayMemberBinding="{Binding InputFileName}"/>
                    <GridViewColumn Header="OUTPUT FILE" Width="220" DisplayMemberBinding="{Binding OutputFileName}"/>
                    <GridViewColumn Header="TYPE"        Width="130" DisplayMemberBinding="{Binding ConversionType}"/>
                    <GridViewColumn Header="PROGRESS"    Width="220">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Width="190">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="38"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Progress, StringFormat={}{0}%}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <Button Content="Show in Explorer →"
                    Command="{Binding ShowOutputFolderCommand}"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>